{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer dairy order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "delivered", "cancelled"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    }
  }
}
